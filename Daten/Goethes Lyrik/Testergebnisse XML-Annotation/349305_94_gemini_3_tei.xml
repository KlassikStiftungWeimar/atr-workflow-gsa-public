<?xml version="1.0" encoding="UTF-8"?>
<text>
    <body>
        <pb/>
        <div type="poem">
            <lg>
                <l>Die schreib' ich immer schöner</l>
                <l>Und mehr nach meinem Sinn,</l>
                <l>Trotz Krittler und Verhöhner,</l>
                <l>Zu täglichem Gewinn.</l>
                <l>Ihr Bild in reichen Schranken</l>
                <l>Verherrlichet sich nur,</l>
                <l>In goldnen Rosenranken.</l>
                <l>Und Rähmchen von Lasur.</l>
            </lg>
        </div>
    </body>
</text>