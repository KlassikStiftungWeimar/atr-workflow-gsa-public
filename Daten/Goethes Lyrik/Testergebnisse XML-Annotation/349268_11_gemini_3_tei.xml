<?xml version="1.0" encoding="UTF-8"?>
<text>
    <body>
        <pb/>
        <div type="poem">
            <head>Der neue Amadis.</head>
            <lg>
                <l>Als ich noch ein Knabe war</l>
                <l>Sperrte man mich ein</l>
                <l>Und so saß ich manches Jahr</l>
                <l>Uber mir allein</l>
                <l>Wie im Mutterleib.</l>
            </lg>
            <lg>
                <l>Doch du warst mein Zeitvertreib</l>
                <l>Goldne Phantasie</l>
                <l>Und ich ward ein warmer Held</l>
                <l>Wie der Prinz Pipi</l>
                <l>Und durchzog die Welt.</l>
            </lg>
            <lg>
                <l>Baute manch Chrystallen Schloß</l>
                <l>Und zerstört' es auch</l>
                <l>Warf mein blinckendes Geschoß</l>
                <l>Drachen durch den Bauch,</l>
                <l>Ja ich war ein Mann!</l>
            </lg>
        </div>
    </body>
</text>