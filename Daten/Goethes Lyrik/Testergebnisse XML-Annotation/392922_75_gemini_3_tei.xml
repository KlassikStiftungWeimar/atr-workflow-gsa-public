<?xml version="1.0" encoding="UTF-8"?>
<text>
    <body>
        <pb n="69"/>
        <div type="poem">
            <head>An den Schlaf.</head>
            <lg>
                <l>Der du mit deinem Mohne</l>
                <l>Selbst Gotteraugen zwingst,</l>
                <l>Und Bettler oft zum Throne</l>
                <l>Zum Mädgen Schäfer bringst,</l>
            </lg>
        </div>
    </body>
</text>