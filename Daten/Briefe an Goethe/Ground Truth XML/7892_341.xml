<?xml version="1.0" encoding="UTF-8"?>
<text xml:id="ra369_source">
    <front>
        <div type="address">
            <note type="editorial"/>
        </div>
    </front>
    <body>
        <div type="letter">
            <pb n="1" facs="ra:digitalisate#369/2341"/>
            <opener>
                <salute>
                    <lb/>
                    <hi rendition="#latin">Monsieur</hi>
                </salute>

                <dateline>
                    <lb/>
                    <placeName>
                        <hi rendition="#latin">Rome</hi>
                    </placeName>
                    <date when="1789-01-20"> 20. <hi rendition="#latin">Janv</hi> 1789</date>
                </dateline>
            </opener>
            <p>
                <lb/>
                <hi rendition="#latin">La Caissette contenante des semences des fleurs a été
                    <lb/>remisé depuis la semaine passé a la Maison de Mons <lb/>Le Conseiller
                    Reiffenstein, lui ayant ecrit a Naples, <lb/> il est actuellement avec <abbr>S.
                        A.</abbr>
                    <abbr>Made </abbr> La Duchesse <lb/>de Saxe Weimar, afin qu'il en donne ses
                    dispositions.</hi>
            </p>
            <p>
                <lb/>
                <hi rendition="#latin">Les petits fraix on été chargé au votre compte.</hi>
            </p>
            <p>
                <lb/>
                <hi rendition="#latin">Vous etes aussi obligeant que vous vous souvenez de moi,
                    &amp; <lb/>de ma soeur. Elle est mariée depuis Juillet passé au <lb/>fils de
                        <abbr>Monsr.</abbr> Volpato, &amp; elle est tres contente autant <lb/>que le
                    peut etre dans le comencement de sa grossesse</hi>
            </p>
            <p>
                <lb/>
                <hi rendition="#latin">Elle a reçu avec reconnoissance votre souvenir.</hi>
            </p>
            <p>
                <lb/>
                <hi rendition="#latin">Si vous me trouvez bon a quelque chose disposez librement
                    <lb/>de celui qui avec la plus parfait consideration &amp; respect <lb/>a
                    l'honneur d'etre tres sincerement</hi>
            </p>
            <closer>
                <salute>
                    <lb/>
                    <hi rendition="#latin">Monsieur <lb/>Votre tres <abbr>humbe </abbr> &amp;
                            <abbr>Obt </abbr>
                        <abbr>Serv</abbr>
                    </hi>
                </salute>
                <signed>
                    <lb/>
                    <hi rendition="#latin">Charles <abbr>Ambe </abbr> Riggi</hi>
                </signed>
            </closer>
        </div>
    </body>
</text>
