<?xml version="1.0" encoding="UTF-8"?>
<text>
    <front>
        <div type="address">
            <note type="editorial"></note>
        </div>
    </front>
    <body>
        <div type="letter">
            <pb n="1"/>
            <opener>
                <lb/><hi rendition="#latin">Copia</hi>
                <lb/><hi rendition="#latin">p.p.</hi>
            </opener>
            <p>
                <lb/><abbr>Ew.</abbr> Wohlgeb? melde ich hierdurch ergebenst
                <lb/>daß H? Hofrath Schütz mir heute eine
                <lb/>könig? preuß? Cabinetsordre gezeigt
                <lb/>hat, in welcher dero allgem. Litt. Zeitung
                <lb/>in Jena in sämmt? preuß? Landen ver-
                <lb break="no"/>boten werden soll, wofern nicht
                <lb/>deren Titel welcher mit der in Halle
                <lb/>übereinstimmend, und ganz ähnlich
                <lb/>seyn soll; verändert wird
            </p>
            <closer>
                <salute>
                    <lb/>Mit grosster Hochachtung beharre ich
                    <lb/><abbr>Ew.</abbr> Wohlgeb?
                </salute>
                <lb/>gehorsamer Diener
                <signed>
                    <lb/>Scharf
                </signed>
            </closer>
            <closer>
                <dateline>
                    <lb/><placeName>Leipzig</placeName>
                    <lb/><date when="1803-11-10">d. 10 Nov.
                    <lb/>1803.</date>
                </dateline>
            </closer>
        </div>
    </body>
</text>
