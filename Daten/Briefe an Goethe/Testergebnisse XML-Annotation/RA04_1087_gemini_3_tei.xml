<?xml version="1.0" encoding="UTF-8"?>
<text>
    <front>
        <div type="address">
            <note type="editorial"/>
        </div>
    </front>
    <body>
        <div type="letter">
            <pb n="1" facs="Image name"/>
            <opener>
                <salute>
                    <lb/>Copia <lb/>
                    <hi rendition="#latin">P.P.</hi>
                </salute>
            </opener>
            <p>
                <lb/><abbr>Ew.</abbr> Wohlgeb<abbr>ohren</abbr> melde ich hierdurch ergebenst
                <lb/>daß <abbr>H<abbr>err</abbr></abbr> Hofrath Schütz mir heute eine
                    <lb/>königl<abbr>ich</abbr> preuß<abbr>ische</abbr> Cabinetsordre gezeigt
                <lb/>hat, in welcher dero allgem<abbr>eine</abbr>
                <hi rendition="#latin">Litt.</hi> Zeitung <lb/>in Jena in sämmtl<abbr>ichen</abbr>
                    preuß<abbr>ischen</abbr> Landen ver <lb break="no"/>boten werden soll, wofern
                nicht <lb/>deren Titel welcher mit der in Halle <lb/>übereinstimmend, und ganz
                ähnlich <lb/>seyn soll; verändert wird </p>
            <closer>
                <salute>
                    <lb/>Mit grosster Hochachtung beharre ich <lb/><abbr>Ew.</abbr>
                        Wohlgeb<abbr>ohren</abbr>
                </salute>
                <lb/>
                <dateline>
                    <lb/>
                    <placeName>Leipzig</placeName>
                    <lb/>
                    <abbr>d.</abbr>
                    <date when="1803-11-10">10 <hi rendition="#latin">Nov.</hi>
                        <lb/>1803.</date>
                </dateline>
                <salute>gehorsamer Diener</salute>
                <signed><lb/>Scharf</signed>
            </closer>
        </div>
    </body>
</text>
